# Copy this file to .env and change every secret before starting the stack.
# See docs/CONTAINER_ENVIRONMENT.md and docs/CONTAINER_ENVIRONMENT_en.md for the full container guide.

# PostgreSQL service variables used by docker compose service db.
POSTGRES_DB=incidents
POSTGRES_USER=incidents
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

# Compose image/build selection. Default uses Docker Hub latest; use docker-compose.build.yml for local builds.
CIR_IMAGE=desalvo/cybersecurity-incident-registry:latest
APP_UID=10001
APP_GID=10001
# If an existing bind mount cannot be made writable by APP_UID/APP_GID, the entrypoint can continue as root to avoid startup failure. Set to 0 to fail fast instead.
CIR_RUN_AS_ROOT_ON_VOLUME_PERMISSION_FAILURE=1

# Application database and secrets used by service web.
DATABASE_URL=postgresql+psycopg2://incidents:replace-with-a-long-random-database-password@db:5432/incidents
SECRET_KEY=replace-with-at-least-32-random-characters-generated-with-openssl-rand-hex-32
ADMIN_INITIAL_PASSWORD=replace-with-a-strong-temporary-admin-password
ADMIN_EMAIL=admin@example.local

# Local Docker Compose defaults use plain HTTP on localhost. Set these to 1 only for real HTTPS production deployments.
CIR_PRODUCTION=0
SESSION_COOKIE_SECURE=0
CIR_FORCE_HSTS=0
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SAMESITE=Lax
MAX_CONTENT_LENGTH=26214400
# Local/test only: set to 1 to disable CSRF validation. Ignored and refused when CIR_PRODUCTION=1.
CIR_DISABLE_CSRF=0
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_STEP_SECONDS=60
LOGIN_LOCKOUT_MAX_SECONDS=900

# Persistent storage. Keep these paths mounted on volumes/PVCs in production.
UPLOAD_DIR=/data/uploads
LOGO_DIR=/data/logo
FORM_TEMPLATE_DIR=/data/form_templates
SSO_LOGO_DIR=/data/sso_logos
SSL_DIR=/data/ssl
BACKUP_DIR=/data/backups
AI_CHATBOT_DOC_DIR=/data/ai_chatbot_docs

# Internal HTTP/HTTPS listeners and Gunicorn tuning.
PORT=8000
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=180
SSL_ENABLED=0
SSL_PORT=8443
# If HTTPS is enabled and these paths are left unset, the container creates/regenerates
# a self-signed host certificate under SSL_DIR. Prefer the CIR_* names for an
# externally managed certificate; the generic SSL_CERT_FILE/SSL_KEY_FILE pair is
# honored only when both variables are set, avoiding CA-bundle collisions.
# CIR_SSL_CERT_FILE=/data/ssl/current.crt
# CIR_SSL_KEY_FILE=/data/ssl/current.key
# SSL_CERT_FILE=/data/ssl/current.crt
# SSL_KEY_FILE=/data/ssl/current.key
# WEB_CONCURRENCY_SSL=1

# Deadline notification/reminder scheduler.
CIR_ENABLE_DEADLINE_SCHEDULER=1
CIR_DEADLINE_SCHEDULER_POLL_SECONDS=60

# Application metadata shown in Info -> Application.
APP_NAME=Cybersecurity Incident Registry
APP_VERSION=0.7.0-7
APP_BUILD=20260608
APP_AUTHOR=Alessandro De Salvo
APP_AUTHOR_EMAIL=Alessandro.DeSalvo@roma1.infn.it
