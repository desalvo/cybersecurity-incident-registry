# Copy this file to .env and change every secret before starting the stack.
# See docs/CONTAINER_ENVIRONMENT.md and docs/CONTAINER_ENVIRONMENT_en.md for the full container guide.

# PostgreSQL service variables used by docker compose service db.
POSTGRES_DB=incidents
POSTGRES_USER=incidents
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

# Application database and secrets used by service web.
DATABASE_URL=postgresql+psycopg2://incidents:replace-with-a-long-random-database-password@db:5432/incidents
SECRET_KEY=replace-with-at-least-32-random-characters-generated-with-openssl-rand-hex-32
ADMIN_INITIAL_PASSWORD=replace-with-a-strong-temporary-admin-password
ADMIN_EMAIL=admin@example.local

# Set to 1 in real production. When enabled the app refuses weak defaults.
CIR_PRODUCTION=1
SESSION_COOKIE_SECURE=1
CIR_FORCE_HSTS=1
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SAMESITE=Lax
MAX_CONTENT_LENGTH=26214400

# Persistent storage. Keep these paths mounted on volumes/PVCs in production.
UPLOAD_DIR=/data/uploads
LOGO_DIR=/data/logo
FORM_TEMPLATE_DIR=/data/form_templates
SSO_LOGO_DIR=/data/sso_logos
SSL_DIR=/data/ssl
BACKUP_DIR=/data/backups

# Internal HTTP/HTTPS listeners and Gunicorn tuning.
PORT=8000
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=180
SSL_ENABLED=0
SSL_PORT=8443
# SSL_CERT_FILE=/data/ssl/current.crt
# SSL_KEY_FILE=/data/ssl/current.key
# WEB_CONCURRENCY_SSL=1

# Deadline notification/reminder scheduler.
CIR_ENABLE_DEADLINE_SCHEDULER=1
CIR_DEADLINE_SCHEDULER_POLL_SECONDS=60

# Application metadata shown in Info -> Application.
APP_NAME=Cybersecurity Incident Registry
APP_VERSION=0.2.1-16
APP_BUILD=2026051901
APP_AUTHOR=Alessandro De Salvo
APP_AUTHOR_EMAIL=Alessandro.DeSalvo@roma1.infn.it
